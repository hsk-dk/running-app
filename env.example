APP_BASE_URL=https://xxx.yyy.zz
DATABASE_PATH=/data/running.db
CORS_ORIGINS=https://xxx.yyy.zz

STRAVA_CLIENT_ID=xxxxxx
STRAVA_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRAVA_REFRESH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRAVA_VERIFY_TOKEN=very-random-secret
STRAVA_ATHLETE_ID=xxxxxxxxxxxx
STRAVA_PUSH_SUBSCRIPTION_CALLBACK_URL=https://xxx.yyy.zz/api/webhooks/strava

# Ollama local LLM settings (for AI training suggestions)
# Set OLLAMA_URL to the address of your Ollama instance (default: http://localhost:11434)
# Set OLLAMA_MODEL to the model you want to use (default: llama3)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
